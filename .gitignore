# =============================================================
# KOERU — .gitignore
# =============================================================

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Môi trường ────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── API Cache (tự sinh, không commit) ─────────────────────────
kanji_api_cache.json
kanji_words_cache.json
*_cache.json

# ── QA Reports (output tạm, sinh lại được) ────────────────────
qa_report.json
qa_report.html
qa_kana_report.json
qa_static_report.json
qa_data_report.json

# ── Node / Playwright ─────────────────────────────────────────
node_modules/
test-results/
playwright-report/
.playwright/

# ── Input assets nặng (ảnh, gif raw) ──────────────────────────
input/images/

# ── Editor / OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*

# Backup files (tu sinh boi scripts)
*.backup.js
*.backup.json

# ── Logs sinh ra bởi scripts ──────────────────────────────────
*.log
batch_fix_kanji.log
still_english_n54.log
untranslated.log
all_english.txt

# ── Export / cache tạm ────────────────────────────────────────
kanji_export.csv
kanji_api_cache.json
kanji_words_cache.json

# ── Claude AI workspace (không cần public) ─────────────────────
.claude/

# ── Thư mục thiết kế / prototype cũ ──────────────────────────
Kanji map/
the-kanji-map-main*/

# ── Raw data JSON (tạm, đã được xử lý vào kanji-data.js) ─────
N1_translated.json
N2_translated.json
N3_translated.json
N4_translated.json
N5_translated.json

# ── Input assets: audio mp3, ảnh raw, zip ─────────────────────
input/
*.zip

# ── Tools nội bộ (script sinh data, không cần deploy) ─────────
tools/KOERU_Template.xlsx
tools/export_translate.py
