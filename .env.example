# =============================================================
# KOERU — Environment Variables Template
# Sao chép file này thành .env (KHÔNG commit .env vào git)
# =============================================================
#
# ── Google Apps Script Properties ─────────────────────────────
# Cách set: Apps Script Editor → Project Settings → Script Properties
# → Add property → nhập Key + Value bên dưới
#
# File này chỉ là TEMPLATE. Giá trị thật đặt trong Script Properties,
# KHÔNG đặt trong code .gs, KHÔNG commit lên GitHub.
# =============================================================

# ── Code.gs (Kanji Data API) ───────────────────────────────────
# ID của Google Sheet chứa dữ liệu Kanji
# Lấy từ URL: https://docs.google.com/spreadsheets/d/<ID>/edit
KANJI_SHEET_ID=your_kanji_spreadsheet_id_here

# Tên sheet mặc định (mặc định: Kanji)
KANJI_SHEET_NAME=Kanji

# ── koeru_triggers.gs (CRM Automation) ────────────────────────
# ID của Google Sheet CRM
CRM_SS_ID=your_crm_spreadsheet_id_here

# Email nhận tất cả thông báo CRM (lead mới, follow-up, retention)
FOUNDER_EMAIL=your_email@example.com

# =============================================================
# Cách setup trên Apps Script:
#
# 1. Mở script tại: https://script.google.com
# 2. Chọn project → ⚙️ Project Settings → Script Properties
# 3. Click "+ Add property"
# 4. Nhập từng cặp Key / Value từ file này
# 5. Save
#
# Sau đó chạy installTriggers() một lần duy nhất.
# =============================================================
